rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    
    // SAFE FALLBACK: Use DB check since we don't have Custom Claims yet.
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isRole(role) { return isSignedIn() && getUserData().role == role; }

    function isAdmin() { return isRole('admin'); }
    function isManagement() { return isRole('management') || isAdmin(); }
    function isStudent() { return isRole('student'); }
    function isInstructor() { return isRole('instructor'); }
    
    // INTEGRITY CHECKS
    function notUpdating(field) { return !(field in request.resource.data) || resource.data[field] == request.resource.data[field]; }
    function notChangingRole() { return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin']); }
    function notSpoofingStats() { return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ratingStats', 'reviewsCount', 'aiScore', 'flagStatus', 'engagementScore']); }

    // --- COLLECTIONS ---

    // --- COLLECTIONS ---

    match /users/{uid} {
      allow read: if isSignedIn(); 
      allow create: if isOwner(uid) || isAdmin(); // Allow admins to register users
      allow update: if (isOwner(uid) && notChangingRole()) || isAdmin();
      allow delete: if isAdmin(); 
    }

    match /instructors/{instructorId} {
      allow read: if true; 
      allow create: if isAdmin() || (isSignedIn() && instructorId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && instructorId == request.auth.uid && notSpoofingStats());
      allow delete: if isAdmin();
    }

    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      
      function onlyUpdatingReactions() {
        return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likesCount', 'dislikesCount', 'reactionCount', 'updatedAt']);
      }

      allow update: if isAdmin() 
                    || (isSignedIn() && resource.data.studentId == request.auth.uid && notSpoofingStats())
                    || (isSignedIn() && onlyUpdatingReactions());
      
      allow delete: if (isSignedIn() && resource.data.studentId == request.auth.uid) || isAdmin(); 
    }

    match /reports/{reportId} {
        allow read: if isAdmin();
        allow create: if isSignedIn(); // Allow users to report issues
        allow update: if isAdmin(); // Resolve
    }
    
    match /system_settings/{settingId} {
        allow read: if true; // Public settings like maintenance mode? Or restricted? Let's say authenticated.
        allow write: if isAdmin();
    }

    match /audit_logs/{logId} { 
        allow read: if isAdmin(); 
        allow create: if isAdmin() || isSignedIn(); // Allow logging actions
    } 

    match /reactions/{reactionId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId); 
      allow update: if isOwner(resource.data.userId);
    }

    match /replies/{replyId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId); 
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    match /messages/{messageId} {
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.receiverId == request.auth.uid || isAdmin()); 
      allow delete: if isAdmin();
    }

    // --- LOCKED COLLECTIONS (Backend Only) ---
    match /ai_insights/{insightId} { allow read: if isManagement(); allow write: if false; }
    
    match /courses/{courseId} { allow read: if true; allow write: if isAdmin(); }
    match /departments/{deptId} { allow read: if true; allow write: if isAdmin(); }
    match /campuses/{campusId} { allow read: if true; allow write: if isAdmin(); }
    match /flags/{flagId} { 
      allow create: if isSignedIn(); 
      allow read: if isManagement() || (isSignedIn() && resource.data.flaggedBy == request.auth.uid);
      allow update, delete: if isManagement(); 
    }
    match /pending_registrations/{uid} { allow read: if isOwner(uid); allow write: if isOwner(uid); }
    
    match /students/{studentId} { 
       allow read: if isSignedIn(); 
       allow create: if isOwner(studentId); 
       allow update: if isOwner(studentId) && notSpoofingStats(); 
    }
    
    match /{document=**} { allow read, write: if false; }
  }
}
